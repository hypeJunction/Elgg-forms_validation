{
	"name": "hypejunction/forms_validation",
	"version": "4.0.0",
	"type": "elgg-plugin",
	"description": "Form validation components for Elgg",
	"homepage": "http://hypejunction.com",
	"keywords": [
		"elgg",
		"plugin",
		"forms",
		"validation"
	],
	"license": "GPL-2.0",
	"authors": [
		{
			"name": "Ismayil Khayredinov",
			"email": "info@hypejunction.com"
		}
	],
	"require": {
		"composer/installers": "^2.0",
		"bower-asset/parsleyjs": "~2.3",
		"php": ">=7.4",
		"elgg/elgg": "^4.0"
	},
	"autoload": {
		"psr-4": {
			"hypeJunction\\FormsValidation\\": "classes/hypeJunction/FormsValidation/"
		}
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	},
	"extra": {
		"elgg-plugin": {
			"elgg-release": "~4.0",
			"id": "forms_validation"
		}
	}
