{
    "name": "hypejunction/forms_validation",
    "version": "7.0.0",
    "type": "elgg-plugin",
    "description": "Form validation components for Elgg",
    "homepage": "https://github.com/hypeJunction/Elgg-forms_validation",
    "keywords": [
        "elgg",
        "plugin",
        "forms",
        "validation"
    ],
    "license": "GPL-2.0-or-later",
    "require": {
        "composer/installers": "^2.0",
        "bower-asset/parsleyjs": "~2.3",
        "php": ">=8.3",
        "ext-intl": "*",
        "elgg/elgg": "~7.0.0"
    },
    "autoload": {
        "psr-4": {
            "hypeJunction\\FormsValidation\\": "classes/hypeJunction/FormsValidation/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    },
    "extra": {
        "elgg-plugin": {
            "elgg-release": "~7.0",
            "id": "forms_validation"
        }
    },
    "authors": [
        {
            "name": "Ismayil Khayredinov",
            "email": "ismayil.khayredinov@gmail.com"
        }
    ]
}
